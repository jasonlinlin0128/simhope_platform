rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 自建 users 文件時，role 必須「不存在」或為 'viewer'（擋自我提權成 developer/admin）
    function roleIsViewerOrAbsent(data) {
      return !('role' in data.keys()) || data.role == 'viewer';
    }

    // 欄位不變式：非 admin 編輯自己文件時必須成立。
    // status / authorUid 用 plain equality（fail-closed：現值缺欄位→error→作者分支false→只有admin能改）。
    // createdAt 用 guarded（不敏感、舊文件可能缺，避免誤擋內容編輯）。
    function statusUnchanged() {
      return request.resource.data.status == resource.data.status;
    }
    function authorUidUnchanged() {
      return request.resource.data.authorUid == resource.data.authorUid;
    }
    function createdAtUnchanged() {
      return !('createdAt' in resource.data.keys())
        || request.resource.data.createdAt == resource.data.createdAt;
    }

    // Users:
    //   讀：登入即可（admin 後台需列使用者）
    //   建：本人只能建「無 role / viewer」文件（首次 Google 登入自動建）；admin 可建任意 role
    //   改：本人不可改自己的 role；admin 可改任何人
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        (request.auth.uid == userId && roleIsViewerOrAbsent(request.resource.data)) ||
        isAdmin()
      );
      allow update: if isSignedIn() && (
        (request.auth.uid == userId
          && !('role' in request.resource.data.diff(resource.data).affectedKeys())) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Tools: 公開可讀，developer/admin 可建立，只有作者或 admin 可修改/刪除
    match /tools/{toolId} {
      allow read: if true;
      allow create: if isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['developer', 'admin']
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isSignedIn() && (
        ( resource.data.authorUid == request.auth.uid
          && authorUidUnchanged()
          && statusUnchanged()
          && createdAtUnchanged() )
        || isAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.authorUid == request.auth.uid || isAdmin()
      );
    }

    // Pain Cards: 同 tools，但用 approval 欄位（pending/approved/rejected）
    match /painCards/{cardId} {
      allow read: if true;
      allow create: if isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['developer', 'admin']
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.approval == 'pending';
      // 無 client 端 painCard 編輯/刪除流程（前台只讀）；作者自核准 approval 屬越權。
      // update/delete 一律僅 admin（不開作者分支，避免越權 + 不必要的攻擊面）。
      allow update, delete: if isAdmin();
    }

    // FAQ：公開可讀；僅 admin 可寫（前端後台 CRUD）
    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 申請/需求：client 不可建（只 server Admin SDK 建，防偽造）；admin 可讀 + 改 status/刪除
    match /requests/{reqId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isAdmin();
    }

    // Passkeys / WebAuthn challenges: 只有 Admin SDK（伺服器端）能存取。
    // client 一律拒絕（公鑰庫與 challenge 不可被前端讀寫）。
    match /passkeys/{id} {
      allow read, write: if false;
    }
    match /webauthnChallenges/{id} {
      allow read, write: if false;
    }
  }
}
