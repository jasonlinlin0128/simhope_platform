# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# internal planning docs (PRD, legacy history) — not for public repo
docs/internal/

# Firebase service account key — never commit this
serviceAccountKey.json

# visual brainstorming sessions
.superpowers/

# Claude Code / tooling run artifacts — never commit
.claude/bash-log.txt
.playwright-mcp/

# Firebase emulator run artifacts (rules tests) — never commit
*-debug.log
/.firebase/
firebase-export-*/
